{
  "name": "@reversense/dexcalibur-ts",
  "version": "1.0.1",
  "description": "Android reverse engineering platform focused on dynamic binary instrumentation automation. tPowered by Frida. Offers a GUI and a Node.JS API",
  "main": "./dist/dexcalibur.js",
  "directories": {
    "test": "test"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/FrenchYeti/dexcalibur-ts.git"
  },
  "dependencies": {
    "@reversense/dexcalibur-frida-compile": "^10.2.5",
    "@types/nedb": "^1.8.11",
    "adm-zip": "^0.4.14",
    "better-sqlite3": "^7.4.3",
    "body-parser": "^1.18.3",
    "busboy": "^0.3.1",
    "chai": "^4.1.2",
    "chalk": "^2.4.1",
    "co": "^4.6.0",
    "cookie-parser": "^1.4.5",
    "event-stream": "^4.0.1",
    "express": "^4.16.3",
    "file-type": "^10.4.0",
    "fix-path": "^3.0.0",
    "glob": "^7.2.0",
    "got": "^10.7.0",
    "js-yaml": "^3.13.1",
    "md5": "^2.2.1",
    "mime-types": "^2.1.20",
    "nedb": "^1.8.0",
    "nedb-async": "^0.1.6",
    "properties": "^1.2.1",
    "r2pipe": "^2.8.0",
    "r2pipe-promise": "^1.6.0",
    "rxjs": "^7.1.0",
    "websocket": "^1.0.32",
    "xml2js": "^0.4.19",
    "xz": "^2.0.2"
  },
  "devDependencies": {
    "@types/chai": "^4.2.11",
    "@types/mocha": "^7.0.2",
    "electron": "^11.1.1",
    "electron-rebuild": "^2.3.4",
    "grunt-contrib-clean": "^2.0.0",
    "grunt-contrib-copy": "^1.0.0",
    "grunt-exec": "^3.0.0",
    "mocha": "^5.2.0",
    "mocha-sinon": "^2.1.0",
    "nyc": "^15.1.0",
    "sinon": "^7.3.2",
    "sinon-chai": "^3.3.0",
    "ts-node": "^8.10.2",
    "typescript": "^3.9.5"
  },
  "optionalDependencies": {
    "frida": "^15.0.19"
  },
  "bin": {
    "dexcalibur": "dexcalibur.js"
  },
  "scripts": {
    "prepare": "npm run build",
    "build": "node ./scripts/run_os_script.js build",
    "build:prod": "DXC_PROD=1 node ./scripts/run_os_script.js build",
    "build:node": "node ./scripts/run_os_script.js prebuild-node && node ./scripts/run_os_script.js build",
    "build:electron": "node ./scripts/run_os_script.js prebuild-electron && node ./scripts/run_os_script.js build",
    "watch": "tsc -w",
    "start": "node --max-old-space-size=4096 ./dist/dexcalibur.js",
    "test": "TS_NODE_COMPILER_OPTIONS='{\"module\":\"commonjs\"}' DEXCALIBUR_TEST=1 DEXCALIBUR_PORT=8081 DEXCALIBUR_HOST=127.0.0.1 mocha -r ts-node/register test/*.test.ts",
    "test:node": "DXC_TEST=1 npm run build:node && npm run test",
    "test:electron": "DXC_TEST=1 npm run build:electron && npm run test",
    "postinstall": "node ./scripts/postinstall.js",
    "o_prebuilt:node:publish": "npmrc dxc-npm &&  cp .npmignore.prebuilt .npmignore && npm run build && npm publish --tag prebuilt && cp .npmignore.default .npmignore",
    "o_prebuilt:electron:publish": "npmrc dxc-npm && cp .npmignore.prebuilt .npmignore && npm run build && npm publish --tag prebuilt-electron && cp .npmignore.default .npmignore",
    "electron:rebuild": "",
    "patch:node": "node ./scripts/run_os_script.js prebuild-node",
    "patch:electron": "node ./scripts/run_os_script.js prebuild-electron",
    "patch:electron:v85": "node ./scripts/run_os_script.js prebuild-electron v85",
    "dist-patch:electron": "node ./scripts/run_os_script.js postbuild-electron",
    "dist-patch:electron:v85": "node ./scripts/run_os_script.js postbuild-electron v85",
    "o_prepublish": "npmrc dxc-npm",
    "publish": "npmrc dxc-npm && cp .npmignore.default .npmignore && npm publish"
  },
  "engines": {
    "node": ">=12.0"
  },
  "author": {
    "name": "Georges-Bastien MICHEL",
    "email": "georges.michel@protonmail.com"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "homepage": "https://github.com/FrenchYeti/dexcalibur",
  "license": "Apache-2.0"
}
