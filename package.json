{
  "name": "@dexcalibur/dexcalibur-ts",
  "version": "1.12.4",
  "description": "Universal Reverse Engineering platform focused on dynamic binary instrumentation automation by Reversense",
  "main": "./dist/dexcalibur.js",
  "directories": {
    "test": "test"
  },
  "repository": {
    "type": "git",
    "url": "git@gitlab.reversense.org:dexcalibur/dexcalibur-ts.git"
  },
  "dependencies": {
    "@dexcalibur/dexcalibur-frida-compile": "^10.2.5",
    "@dexcalibur/dexcalibur-orm": "^1.1.4",
    "@dexcalibur/dexcalibur-orm-mongodb": "^1.5.6",
    "@dexcalibur/dxc-core-api": "^1.7.7",
    "@dexcalibur/dxc-frida-compile": "^16.4.8",
    "@dexcalibur/dxc-orgs": "^1.3.0",
    "@dexcalibur/dxc-parser-properties": "^1.1.3",
    "@dexcalibur/dxc-struct": "^1.0.1",
    "@reversense/interruptor": "^1.0.12",
    "adm-zip": "^0.4.14",
    "body-parser": "^1.20.3",
    "busboy": "^0.3.1",
    "chalk": "^5.6.2",
    "co": "^4.6.0",
    "cookie-parser": "^1.4.5",
    "event-stream": "^4.0.1",
    "express": "^4.16.3",
    "express-session": "^1.17.3",
    "fast-xml-parser": "^5.2.5",
    "file-type": "^10.4.0",
    "fix-path": "^3.0.0",
    "frida": "^16.4.10",
    "frida-compile": "^19.0.4",
    "glob": "^7.2.0",
    "got": "^11.1.3",
    "js-yaml": "^3.13.1",
    "md5": "^2.2.1",
    "mime-types": "^2.1.20",
    "mongodb": "^6.17.0",
    "node-forge": "^1.3.1",
    "openid-client": "^5.5.0",
    "passport": "^0.6.0",
    "passport-openidconnect": "^0.1.2",
    "properties": "^1.2.1",
    "rxjs": "^7.1.0",
    "typescript": "^5.0.2",
    "websocket": "^1.0.32",
    "xml2js": "^0.4.19",
    "xz": "^2.0.2"
  },
  "devDependencies": {
    "@types/chai": "^4.2.11",
    "@types/express": "^4.17.17",
    "@types/mocha": "^7.0.2",
    "@types/node-forge": "^1.3.0",
    "chai": "^4.3.10",
    "grunt-contrib-clean": "^2.0.0",
    "grunt-contrib-copy": "^1.0.0",
    "grunt-exec": "^3.0.0",
    "mocha": "^10.2.0",
    "nyc": "^15.1.0",
    "sinon": "^7.3.2",
    "sinon-chai": "^3.3.0",
    "ts-node": "^10.9.1",
    "typedoc": "^0.28.4"
  },
  "bin": {
    "dexcalibur": "dexcalibur.js"
  },
  "scripts": {
    "prepare": "npm run build",
    "build": "node ./scripts/run_os_script.mjs build",
    "build:dxsecurity:dev": "node ./scripts/run_os_script.mjs build && cp -r $PWD/../dexcalibur-agent/dist $PWD/dist/agent && ln -s $HOME/WebstormProjects/dxc-ui-reverse/dist/dxc-ui-reverse $PWD/dist/src/webserver/www/pro",
    "build:dxprivacy:dev": "node ./scripts/run_os_script.mjs build && cp -r $PWD/../dexcalibur-agent/dist $PWD/dist/agent && ln -s $HOME/WebstormProjects/dexcalibur-home/dist/dexcalibur-home $PWD/dist/src/webserver/www/home && ln -s $HOME/WebstormProjects/dxc-ui-reverse/dist/dxc-ui-reverse $PWD/dist/src/webserver/www/pro",
    "build:oracle:dev": "node ./scripts/run_os_script.mjs build && cp -r $PWD/../dexcalibur-agent/dist $PWD/dist/agent && ln -s $HOME/WebstormProjects/dexcalibur-home/dist/dexcalibur-home $PWD/dist/src/webserver/www/home && ln -s $HOME/WebstormProjects/dxc-ui-oracle/dist/dxc-ui-oracle $PWD/dist/src/webserver/www/oracle && ln -s $HOME/WebstormProjects/dxc-ui-reverse/dist/dxc-ui-reverse $PWD/dist/src/webserver/www/pro",
    "build:dev": "./build.sh && cp -r $PWD/../dexcalibur-agent/dist $PWD/dist/agent && ln -s $HOME/WebstormProjects/dexcalibur-home/dist/dexcalibur-home $PWD/dist/src/webserver/www/home && ln -s $PWD/../../dxc-ui-reverse/dist/dxc-ui-reverse $PWD/dist/src/webserver/www/pro  ",
    "build:prod": "DXC_PROD=1 node ./scripts/run_os_script.mjs build",
    "build:node": "node ./scripts/run_os_script.mjs prebuild-node && node ./scripts/run_os_script.mjs build",
    "watch": "tsc -w",
    "start": "node --max-old-space-size=4096 ./dist/dexcalibur.js",
    "test": "TS_NODE_COMPILER_OPTIONS='{\"module\":\"es2020\"}' DEXCALIBUR_TEST=1 DEXCALIBUR_PORT=8081 DEXCALIBUR_HOST=127.0.0.1 mocha -r ts-node/register test/*.test.ts",
    "test:node": "DXC_TEST=1 npm run build:node && npm run test",
    "postinstall": "node ./scripts/postinstall.js",
    "o_prebuilt:node:publish": "npmrc dxc-npm &&  cp .npmignore.prebuilt .npmignore && npm run build && npm publish --tag prebuilt && cp .npmignore.default .npmignore",
    "electron:rebuild": "",
    "patch:node": "node ./scripts/run_os_script.mjs prebuild-node",
    "o_prepublish": "npmrc dxc-npm",
    "publish": "npmrc dxc-npm && cp .npmignore.default .npmignore && npm publish"
  },
  "engines": {
    "node": ">=12.0"
  },
  "type": "module",
  "author": {
    "name": "Georges-Bastien MICHEL",
    "email": "georges.michel@protonmail.com"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "homepage": "https://github.com/FrenchYeti/dexcalibur",
  "license": "Copyright Georges-B Michel , Reversense SAS (See LICENSE.MD)",
  "publishConfig": {
    "@dexcalibur:registry": "https://gitlab.reversense.org/api/v4/projects/30/packages/npm/"
  }
}
